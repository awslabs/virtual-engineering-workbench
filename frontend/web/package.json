  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest --passWithNoTests --run",
    "test:ci": "vitest --passWithNoTests --run --coverage",
    "lint": "eslint src --ext ts,tsx --fix",
    "test:cypress:info": "yarn cypress info",
    "test:cypress:verify": "yarn cypress verify",
    "test:cypress:run": "yarn cypress run",
    "test:cypress:electron": "yarn cypress run --browser electron",
    "test:cypress:chrome": "yarn cypress run --browser chrome",
    "test:cypress:firefox": "yarn cypress run --browser firefox",
    "test:cypress:parallel:run": "yarn run build && npx concurrently \"yarn run preview\" \"yarn cypress-parallel -d cypress -s test:cypress:run -t 4 -m false -v\" --kill-others --success=first --raw",
    "test:cypress:parallel:electron": "yarn run build && npx concurrently \"yarn run preview\" \"yarn cypress-parallel -d cypress -s test:cypress:electron -t 4 -m false -v\" --kill-others --success=first --raw",
    "test:cypress:parallel:chrome": "yarn run build && npx concurrently \"yarn run preview\" \"yarn cypress-parallel -d cypress -s test:cypress:chrome -t 4 -m false -v\" --kill-others --success=first --raw",
    "test:cypress:parallel:firefox": "yarn run build && npx concurrently \"yarn run preview\" \"yarn cypress-parallel -d cypress -s test:cypress:firefox -t 4 -m false -v\" --kill-others --success=first --raw",
    "test:cypress:open": "yarn run build && npx concurrently \"yarn run preview\" \"yarn cypress open\" --kill-others --success=first --raw"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.30.0",
