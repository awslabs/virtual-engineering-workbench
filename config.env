# VEW Deployment Configuration
# Copy to deploy-config.env and fill in values, then run:
#   ./deploy.sh --config deploy-config.env

# Required
AWS_ACCOUNT_ID="123456789012"
AWS_REGION="us-east-1"
ENVIRONMENT="dev"
ORG_PREFIX="proserve"
APP_PREFIX="wb"
ADMIN_EMAIL="admin@example.com"
ADMIN_USER_ID="ADMIN"

# AWS CLI profiles (leave empty for default)
AWS_PROFILE_HUB=""
AWS_PROFILE_SPOKE=""

# OIDC federation (leave empty for manual Cognito users)
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_ISSUER_URL=""

# TLS and custom domain (leave empty for CloudFront-only access)
CERT_ARN=""
CERT_ARN_US_EAST_1=""
CUSTOM_DOMAIN=""
API_CUSTOM_DOMAIN=""

# Spoke account (leave empty to skip)
SPOKE_ACCOUNT_ID=""
SPOKE_VPC_ID=""
